# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# ─── Auth (JWT + MFA) ──────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars

# Legacy register endpoint (disabled by default)
AUTH_ENABLE_LEGACY_REGISTER=false

# Dev-only env seed (disabled by default; avoid in production)
AUTH_ENABLE_ENV_SEED=false
SEED_ADMIN_EMAIL=admin@your-msp.com
SEED_ADMIN_PASSWORD=your-strong-password-min-12-chars
SEED_TENANT_NAME=My MSP
SEED_ADMIN_TOKEN=change_me_to_random_token

# Platform control-plane admin token (required for /platform/admin/* endpoints)
PLATFORM_ADMIN_TOKEN=change_me_to_long_random_token
PLATFORM_MASTER_EMAIL=admin@cerebro.local

# ─── SMTP (local Mailpit by default) ─────────────────────────
SMTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cerebro <no-reply@cerebro.local>

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql://playbook:playbook_dev@localhost:5432/cerebro

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM (choose one provider) ─────────────────────────────
# Free options: groq, minimax (M2.5)
# Paid options: anthropic
LLM_PROVIDER=groq

# Groq (FREE - Recommended - https://console.groq.com)
GROQ_API_KEY=gsk_...

# Minimax M2.5 (free tier available - https://platform.minimaxi.com)
MINIMAX_API_KEY=sk-...

# Anthropic Claude (paid - https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# LLM Config
LLM_MAX_TOKENS_DIAGNOSE=3000
LLM_MAX_TOKENS_PLAYBOOK=2000
LLM_MODEL=llama-3.3-70b-versatile  # (for Groq - check https://console.groq.com for available models)
LLM_TIMEOUT_MS=30000

# ─── Autotask ──────────────────────────────────────
# Get these from: Admin > API > Integration > New Integration
AUTOTASK_API_INTEGRATION_CODE=your_integration_code
AUTOTASK_USERNAME=your_api_user@example.com
AUTOTASK_SECRET=your_api_secret
AUTOTASK_ZONE_URL=   # Optional — auto-discovered via zoneInformation endpoint

# ─── NinjaOne ──────────────────────────────────────
# Get these from: Administration > Apps > API > Add
NINJAONE_CLIENT_ID=your_client_id
NINJAONE_CLIENT_SECRET=your_client_secret
NINJAONE_BASE_URL=   # Optional — defaults to https://app.ninjarmm.com (EU: eu, OC: oc)

# ─── IT Glue ───────────────────────────────────────
# Get these from: Account > Settings > API Keys > Generate
ITGLUE_API_KEY=your_itglue_api_key
ITGLUE_BASE_URL=     # Optional — defaults to https://api.itglue.com (EU: api.eu.itglue.com)

# ─── Cache TTLs (seconds) ──────────────────────────
CACHE_TTL_ISP_STATUS=300       # 5 min
CACHE_TTL_NETWORK_STACK=3600   # 1 hora
CACHE_TTL_KNOWN_ISSUES=86400   # 24 horas

# ─── Security ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
API_RATE_LIMIT_RPM=60

# ─── Auth (Google OAuth) ───────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
